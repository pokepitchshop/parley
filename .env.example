# Copy to .env for local development. Never commit .env.
SPRING_PROFILES_ACTIVE=local
# Azure OpenAI — portal → parley-dev-openai → Keys and Endpoint (KEY 1 + endpoint URL)
AZURE_OPENAI_API_KEY=
SPRING_AI_OPENAI_BASE_URL=https://parley-dev-openai.openai.azure.com/
SPRING_AI_OPENAI_CHAT_MICROSOFT_DEPLOYMENT_NAME=gpt-4.1-mini
# Local: mongodb://localhost:27017/parley (requires local MongoDB)
# Azure deploy: MongoDB Atlas URI — see docs/azure-deploy.md § MongoDB (Atlas)
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/parley
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 number to repoint (see scripts/repoint-twilio-voice-webhook.sh)
TWILIO_FROM_NUMBER=
# ngrok HTTPS forwarding URL (see docs/twilio-public-url.md) or Azure app_url (see docs/azure-deploy.md)
PUBLIC_BASE_URL=

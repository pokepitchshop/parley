# Copy to dev.tfvars and fill in. dev.tfvars is gitignored.
# Shared, non-secret config read by all three layers.
subscription_id = "00000000-0000-0000-0000-000000000000" # TODO: your Azure subscription ID
location        = "eastus2"
environment     = "dev"
project         = "parley"

# app layer (cheap dev defaults — scale to zero when idle)
min_replicas = 0
max_replicas = 2

# platform layer (cap log ingestion so logs can't surprise-bill)
log_analytics_daily_quota_gb = 0.5

# NOTE: app-layer secrets (twilio_account_sid, twilio_token_secret_id,
# mongodb_uri_secret_id) do NOT go here. Set them as workspace variables on the parley-app HCP workspace.
